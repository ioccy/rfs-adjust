// Icon with lowest ID value placed first to ensure application icon
// remains consistent on all systems.
IDI_APPICON             ICON                    "appicon.ico"

IDI_SMALL               ICON                    "appicon.ico"


/////////////////////////////////////////////////////////////////////////////
//
// Menu
//

IDC_MAINMENU MENU
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "&Reset to zero",              IDM_RESET, GRAYED
        MENUITEM "&Terminal ...",               IDM_TERMINAL, GRAYED
        MENUITEM "E&xit",                       IDM_EXIT
    END
    POPUP "&Help"
    BEGIN
        MENUITEM "&About ...",                  IDM_ABOUT
    END
END


/////////////////////////////////////////////////////////////////////////////
//
// Accelerator
//

IDC_FEISET ACCELERATORS
BEGIN
    "?",            IDM_ABOUT,              ASCII,  ALT
    "/",            IDM_ABOUT,              ASCII,  ALT
END


/////////////////////////////////////////////////////////////////////////////
//
// Dialog
//

IDD_ABOUTBOX DIALOGEX 0, 0, 201, 121
STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "About"
FONT 8, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    ICON            IDI_APPICON,IDC_STATIC,14,14,21,20
    LTEXT           "Adjusts frequency offset for FE-5650A Option CPOM and FE-5680A Option 2 that use binary protocol",IDC_ABT_DESC,42,39,132,24,SS_NOPREFIX
    DEFPUSHBUTTON   "OK",IDOK,128,100,50,14,WS_GROUP
    CONTROL         "Webpage link",IDC_LINK,"SysLink",WS_TABSTOP,42,69,150,12
    LTEXT           "Name",IDC_ABT_NAME,42,16,132,8
    LTEXT           "Version",IDC_ABT_VER,42,25,132,8
END

IDD_MAIN DIALOGEX 0, 0, 104, 140
STYLE DS_SETFONT | DS_FIXEDSYS | WS_CHILD
FONT 8, "MS Shell Dlg", 400, 0, 0x0
BEGIN
    PUSHBUTTON      "Apply",IDC_APPLY,6,116,42,14,WS_DISABLED
    PUSHBUTTON      "Save",IDC_SAVE,54,116,42,14,WS_DISABLED
    COMBOBOX        IDC_PORT,50,4,46,30,CBS_DROPDOWNLIST | CBS_SORT | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Serial port:",IDC_STATIC,9,7,36,8
    GROUPBOX        "Offset, Hz",IDC_STATIC,6,24,90,25
    CTEXT           "",IDC_CURRENT,12,35,78,10
    GROUPBOX        "Offset adjustment",IDC_STATIC,6,54,90,60
    EDITTEXT        IDC_EDIT,22,80,58,12,ES_CENTER | ES_AUTOHSCROLL | WS_DISABLED | NOT WS_BORDER,WS_EX_CLIENTEDGE | WS_EX_RIGHT
    PUSHBUTTON      "▲",IDC_UP0,64,66,15,14,WS_DISABLED
    PUSHBUTTON      "▲",IDC_UP3,22,66,15,14,WS_DISABLED
    PUSHBUTTON      "▲",IDC_UP2,36,66,15,14,WS_DISABLED
    PUSHBUTTON      "▲",IDC_UP1,50,66,15,14,WS_DISABLED
    PUSHBUTTON      "▼",IDC_DN0,64,93,15,14,WS_DISABLED
    PUSHBUTTON      "▼",IDC_DN3,22,93,15,14,WS_DISABLED
    PUSHBUTTON      "▼",IDC_DN2,36,93,15,14,WS_DISABLED
    PUSHBUTTON      "▼",IDC_DN1,50,93,15,14,WS_DISABLED
