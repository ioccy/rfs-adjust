    CONTROL         "I want to brick my device",IDC_TER_CONSENT,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,12,36,96,10
    GROUPBOX        "Terminal input",IDC_TER_GROUP,12,156,282,36,WS_DISABLED
