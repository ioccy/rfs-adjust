    LISTBOX         IDC_TER_OUTPUT,12,54,282,98,LBS_NOINTEGRALHEIGHT | LBS_NOSEL | WS_VSCROLL | WS_HSCROLL
    EDITTEXT        IDC_TER_INPUT,18,169,216,14,ES_UPPERCASE | ES_AUTOHSCROLL | WS_DISABLED
    DEFPUSHBUTTON   "Send",IDC_TER_SEND,240,169,50,14,WS_DISABLED
